import torch
import torch.nn as nn
import torch.optim as optim

import gymnasium as gym
from gymnasium.wrappers import RecordVideo

import os
import numpy as np
from collections import namedtuple
from tensorboardX import SummaryWriter

HIDDEN_SIZE = 256
BATCH_SIZE = 32
PERCENTILE = 70

class Policy(nn.Module):
  def __init__(self, observation_size, hidden_size, n_actions):
    super(Policy, self).__init__()
    self.model = nn.Sequential(
        nn.Linear(in_features=observation_size, out_features=hidden_size),
        nn.ReLU(),
        nn.Linear(in_features=hidden_size, out_features=n_actions)
    )

  def forward(self, x):
    return self.model(x)

Episode = namedtuple(typename="Episode", field_names=['reward', 'steps'])
EpisodeStep = namedtuple(typename='EpisodeStep', field_names=['observation', 'action'])

def iterate_batches(env, policy, batch_size):
  batch = []
  episode_reward = 0.0
  episode_steps = []
  obs, _ = env.reset()
  sm = nn.Softmax(dim=1)

  # game generator
  while True:
    obs_v = torch.tensor([obs], dtype=torch.float) # 1X4

    # pass the observation into the model
    policy.eval()
    with torch.inference_mode():
      act_probs_v = sm(policy(obs_v))
      # get action probability distribution
      act_probs = act_probs_v.numpy()[0] # act_probs sums up to 1

      # select an action for the current observation by sampling the distribution
      action = np.random.choice(len(act_probs), p=act_probs)

    # pass action in the environment
    next_obs, reward, terminated, truncated, _ = env.step(action)

    episode_reward += reward
    episode_step = EpisodeStep(observation=obs, action=action)
    episode_steps.append(episode_step)

    if terminated or truncated:
      e = Episode(reward=episode_reward, steps=episode_steps)
      batch.append(e)

      # reset params
      episode_reward = 0.0
      episode_steps = []
      next_obs, _ = env.reset()
      if len(batch) == batch_size:
        yield batch
        batch = []
    obs = next_obs


def filter_batch(batches, percentile):
  rewards = [s.reward for s in batches] # or list(map(lambda s: s.reward, batches))
  reward_bound = np.percentile(rewards, percentile)
  reward_mean = float(np.mean(rewards))

  train_obs = []
  train_act = []
  for reward, steps in batches:
    if reward < reward_bound:
      continue
    train_obs.extend(map(lambda step: step.observation, steps))
    train_act.extend(map(lambda step: step.action, steps))

  # convert to tensors
  train_obs_v = torch.tensor(train_obs, dtype=torch.float)
  train_act_v = torch.tensor(train_act, dtype=torch.long)
  return train_obs_v, train_act_v, reward_bound, reward_mean

if __name__ == "__main__":
  env = gym.make("CartPole-v1", render_mode="rgb_array")

  # video feedback
  video_folder = "recordings"
  if not os.path.exists(video_folder):
    os.makedirs(video_folder)
  # record every 10 episodes 
  env = RecordVideo(env, video_folder=video_folder, episode_trigger=lambda x: x % 10 == 0)

  obs_size = env.observation_space.shape[0]
  n_actions = env.action_space.n

  policy = Policy(obs_size, HIDDEN_SIZE, n_actions)
  criterion = nn.CrossEntropyLoss()
  optimizer = optim.Adam(params=policy.parameters(), lr=1e-2)
  writer = SummaryWriter(comment="-cartpole-v1")  

  for iter_no, batch in enumerate(iterate_batches(env, policy, BATCH_SIZE)):
    obs_v, acts_v, reward_b, reward_m = filter_batch(batch, PERCENTILE)

    policy.train()
    actions_scores_v = policy(obs_v)

    optimizer.zero_grad()
    loss_v = criterion(actions_scores_v, acts_v)
    loss_v.backward()

    optimizer.step()

    print(f"episode: {iter_no} | loss: {loss_v.item():.3f} | reward_mean; {reward_m:.3f} | reward_bound: {reward_b:.3f}")
    writer.add_scalar("loss", loss_v.item(), iter_no)
    writer.add_scalar("reward_bound", reward_b, iter_no)
    writer.add_scalar("reward_maen", reward_m, iter_no)

    if reward_m > 199:
      print("Problem Solved <3")
      break

  writer.close()
  env.close() # close env to finish video recording
